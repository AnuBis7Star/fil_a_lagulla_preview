---
import { quickInfo } from '../data/site';
---
<section class="quick-info" aria-label="Informació ràpida">
  <div class="wrap quick-grid reveal">
    {quickInfo.map((item) => (
      <article>
        <span>{item.label}</span>
        <strong>{item.value}</strong>
      </article>
    ))}
  </div>
</section>
