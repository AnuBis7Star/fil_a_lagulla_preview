---
import { business, stats } from '../data/site';
import { withBase } from '../utils/paths';
---
<section class="hero" id="top">
  <div class="wrap hero-grid">
    <div class="hero-copy reveal">
      <span class="eyebrow"><span class="dot"></span> Taller de costura a Reus</span>
      <h1>Roba feta amb cura, puntada a puntada.</h1>
      <p class="lead">
        Arranjaments de roba, baixos, cremalleres, ajustos, transformacions i peces a mida fetes amb calma al taller.
      </p>
      <div class="hero-actions">
        <a class="btn" href="#contacte">Consultar per WhatsApp</a>
        <a class="btn alt" href="#treballs">Veure treballs</a>
      </div>
      <div class="stats" aria-label="Dades destacades">
        {stats.map((stat) => (
          <div class="stat">
            <b>{stat.value}</b>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="visual reveal" aria-label="Fotografies del taller">
      <div class="hero-card main"><img src={withBase(business.heroMain)} alt="Façana del taller Fil a l'Agulla a Reus" /></div>
      <div class="hero-card side"><img src={withBase(business.heroSide)} alt="Vestits blancs fets a mida" /></div>
      <div class="logo-badge"><img src={withBase(business.logo)} alt={`Logo ${business.name}`} /></div>
      <div class="floating-note"><b>Roba a mida</b><span>Vestits, arranjaments, transformacions i peces úniques fetes al taller.</span></div>
    </div>
  </div>
</section>
