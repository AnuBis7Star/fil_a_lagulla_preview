---
import { gallery } from '../data/site';
const base = import.meta.env.BASE_URL;
---
<section id="treballs">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <span class="kicker">Treballs</span>
        <h2>Un aparador digital amb el mateix encant que el taller.</h2>
      </div>
      <p>
        Les imatges transmeten ofici, proximitat i confiança abans que el client entri per la porta.
      </p>
    </div>
    <div class="gallery-grid">
      {gallery.map((item) => (
        <figure class={`shot ${item.className} reveal`}>
          <img src={`${base}${item.image}`} alt={item.title} loading="lazy" />
          <figcaption class="label">
            <strong>{item.title}</strong>
            <span>{item.text}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
